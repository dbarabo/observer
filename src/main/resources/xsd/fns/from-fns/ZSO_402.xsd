<?xml version="1.0" encoding="windows-1251"?>
<!-- edited with XMLSpy v2011 sp1 (http://www.altova.com) by Shakeev (FGUP GNIVC FNS Russia) -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:sch="http://purl.oclc.org/dsdl/schematron" xmlns:usch="http://www.unisoftware.ru/schematron-extensions" xmlns:sql="urn:schemas-microsoft-com:mapping-schema" xmlns:altova="http://www.altova.com/xml-schema-extensions" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:element name="Файл">
		<xs:annotation>
			<!---**************************************************************************************************************************************************************************-->
			<xs:appinfo>
				<sch:pattern name="Проверка имени файла на соответствие значению атрибута @ИдФайл">
					<sch:rule context="Файл">
						<!--  1. Проверка имени файла на соответствие ИдФайл                                                                             -->
						<sch:assert test="usch:getFileName() = @ИдФайл">
							<usch:error code="0400400007" path="@ИдФайл" value-of-select="@ИдФайл" doc-id-path="usch:getFileName()" doc-id-caption="Файл">Имя файла обмена "<usch:value-of select="usch:getFileName()"/>" не совпадает со значением элемента ИдФайл "<usch:value-of select="@ИдФайл"/>"</usch:error>
						</sch:assert>
					</sch:rule>
				</sch:pattern>
			</xs:appinfo>
			<!---**************************************************************************************************************************************************************************-->
			<xs:documentation>Файл обмена</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="ЗАПНООСТАТ" maxOccurs="1">
					<xs:annotation>
						<xs:documentation>Состав и структура документа</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="МотивЗапр">
								<xs:annotation>
									<xs:documentation>Мотивировочная часть запроса</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="Обоснов" maxOccurs="unbounded">
											<xs:annotation>
												<xs:documentation>Обоснование запроса</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="СвПлОбоснов" type="СвПлОбоснов">
														<xs:annotation>
															<xs:documentation>Сведения о плательщике, в отношении которого проводятся мероприятия, указанные в обосновании</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
												<xs:attribute name="КодОбоснов" use="required">
													<xs:annotation>
														<xs:documentation>Код обоснования запроса</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:nonNegativeInteger">
															<xs:totalDigits value="2"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
															<xs:enumeration value="3"/>
															<xs:enumeration value="4"/>
															<xs:enumeration value="5"/>
															<xs:enumeration value="6"/>
															<xs:enumeration value="7"/>
															<xs:enumeration value="8"/>
															<xs:enumeration value="9"/>
															<xs:enumeration value="10"/>
															<xs:enumeration value="11"/>
															<xs:enumeration value="12"/>
															<xs:enumeration value="13"/>
															<xs:enumeration value="14"/>
															<xs:enumeration value="15"/>
															<xs:enumeration value="16"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ВидПров" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ВидПров в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=1 or @КодОбоснов=2 or @КодОбоснов=3, count(@ВидПров)!=0, count(@ВидПров)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ВидПров обязателен при значении элемента КодОбоснов=1 | 2 | 3 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Вид налоговой проверки</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:length value="1"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
															<xs:enumeration value="3"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="НаимНО" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента НаимНО в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@НаимНО)!=0, count(@НаимНО)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент НаимНО обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Краткое наименование налогового органа, согласовавшего направление запроса в банк, оператору платформы цифрового рубля</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:minLength value="1"/>
															<xs:maxLength value="160"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="КодНО" type="ИФНСТип" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента КодНО в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@КодНО)!=0, count(@КодНО)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент КодНО обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Код налогового органа, согласовавшего направление запроса</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ДолжнЛицСогл" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ДолжнЛицСогл в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@ДолжнЛицСогл)!=0, count(@ДолжнЛицСогл)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ДолжнЛицСогл обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Должность лица, согласовавшего направление запроса</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:length value="1"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
															<xs:enumeration value="3"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ФИОЛицСогл" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ФИОЛицСогл в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@ФИОЛицСогл)!=0, count(@ФИОЛицСогл)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ФИОЛицСогл обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Фамилия, имя, отчество (при наличии) лица, согласовавшего направление запроса</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:minLength value="1"/>
															<xs:maxLength value="100"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ВидДокСогл" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ВидДокСогл в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@ВидДокСогл)!=0, count(@ВидДокСогл)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ВидДокСогл обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Вид документа о согласии о направлении запроса в банк (оператору платформы цифрового рубля)</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:minLength value="1"/>
															<xs:maxLength value="50"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ДатаДокСогл" type="xs:date" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ДатаДокСогл в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@ДатаДокСогл)!=0, count(@ДатаДокСогл)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ДатаДокСогл обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Дата документа о согласии о направлении запроса</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="НомерДокСогл" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента НомерДокСогл в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=2 or @КодОбоснов=5, count(@НомерДокСогл)!=0, count(@НомерДокСогл)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент НомерДокСогл обязателен при значении элемента КодОбоснов=2 | 5 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Номер документа о согласии о направлении запроса</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:minLength value="1"/>
															<xs:maxLength value="50"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ВидСделки" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ВидСделки в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=3 or @КодОбоснов=6 or @КодОбоснов=16, count(@ВидСделки)!=0, count(@ВидСделки)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ВидСделки обязателен при значении элемента КодОбоснов=3 | 6 | 16 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Вид сделки (операции)/ совокупности сделок (операций)</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:length value="1"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ТипЛица" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ТипЛица в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=3 or @КодОбоснов=6 or @КодОбоснов=16, count(@ТипЛица)!=0, count(@ТипЛица)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ТипЛица обязателен при значении элемента КодОбоснов=3 | 6 | 16 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Статус организации, в отношении которой направляется запрос</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:length value="1"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
															<xs:enumeration value="3"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ВидРешПр" use="optional">
													<xs:annotation>
														<!--************************************************************************************************************************************************************-->
														<xs:appinfo>
															<sch:pattern name="Проверка присутствия (отсутствия) элемента ВидРешПр в зависимости от значения элемента КодОбоснов">
																<sch:rule context="Обоснов">
																	<sch:assert test="usch:iif(@КодОбоснов=8, count(@ВидРешПр)!=0, count(@ВидРешПр)=0)">
																		<usch:error code="0400300003" path="" value-of-select="">Не выполнено условие: Элемент ВидРешПр обязателен при значении элемента КодОбоснов=8 , и должен отсутствовать при остальных значениях элемента КодОбоснов</usch:error>
																	</sch:assert>
																</sch:rule>
															</sch:pattern>
														</xs:appinfo>
														<!--*************************************************************************************************************************************************************-->
														<xs:documentation>Вид решения</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:length value="1"/>
															<xs:enumeration value="1"/>
															<xs:enumeration value="2"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
									</xs:sequence>
									<xs:attribute name="КодОснов" use="required">
										<xs:annotation>
											<xs:documentation>Код основания запроса</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:length value="1"/>
												<xs:enumeration value="1"/>
												<xs:enumeration value="2"/>
												<xs:enumeration value="3"/>
												<xs:enumeration value="4"/>
												<xs:enumeration value="5"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="СвНО" type="СвНОТип">
								<xs:annotation>
									<xs:documentation>Сведения о налоговом органе</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:choice>
								<xs:element name="СвБанк" type="БанкТип">
									<xs:annotation>
										<xs:documentation>Сведения о банке</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="СвУБР" type="УБРТип">
									<xs:annotation>
										<xs:documentation>Сведения о подразделении Банка России</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:choice>
							<xs:element name="СвПл" type="СвПлТип">
								<xs:annotation>
									<xs:documentation>Сведения о лице, в отношении которого сформирован запрос</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:choice>
								<xs:element name="ПоВсем">
									<xs:annotation>
										<xs:documentation>Запрос об остатках денежных средств (драгоценных металлов) на всех счетах в банке (специальных банковских счетах, вкладах, депозитах), счете цифрового рубля, об остатках электронных денежных средств</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:choice>
											<xs:element name="НаДату">
												<xs:annotation>
													<xs:documentation>Действовавших по состоянию на дату</xs:documentation>
												</xs:annotation>
												<xs:complexType>
													<xs:attribute name="ДейстПоСост" use="required">
														<xs:annotation>
															<xs:documentation>Дата</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
															<xs:restriction base="xs:date"/>
														</xs:simpleType>
													</xs:attribute>
												</xs:complexType>
											</xs:element>
											<xs:element name="ВПериод">
												<xs:annotation>
													<xs:documentation>Действовавших в период</xs:documentation>
												</xs:annotation>
												<xs:complexType>
													<xs:attribute name="ДатаНач" use="required">
														<xs:annotation>
															<xs:documentation>Дата начала периода</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
															<xs:restriction base="xs:date"/>
														</xs:simpleType>
													</xs:attribute>
													<xs:attribute name="ДатаКон" use="required">
														<xs:annotation>
															<xs:documentation>Дата окончания периода</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
															<xs:restriction base="xs:date"/>
														</xs:simpleType>
													</xs:attribute>
												</xs:complexType>
											</xs:element>
										</xs:choice>
										<xs:attribute name="ОстПоСост" use="required">
											<xs:annotation>
